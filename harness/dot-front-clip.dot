digraph "front-clip" {
  rankdir=LR; bgcolor="transparent"; splines=ortho; forcelabels=true; nodesep=0.45; ranksep=1.1;
  node [shape=box, style="rounded,filled", color="#2a323f", fontcolor="#e7ecf3", fontsize=10, fontname="Helvetica"];
  edge [dir=none, fontsize=8, fontname="Helvetica", fontcolor="#cdd0c4"];
  "battery" [label="Battery", fillcolor="#161d28"];
  "pdm" [label="Headlight power centre", fillcolor="#13201a"];
  "bh4" [label="BH4", fillcolor="#1c2530", color="#5a6678", penwidth=2];
  "hl-L" [label="Headlight LEFT", fillcolor="#161d28"];
  "hl-R" [label="Headlight RIGHT", fillcolor="#161d28"];
  "park-fl" [label="Front position/park LEFT", fillcolor="#161d28"];
  "park-fr" [label="Front position/park RIGHT", fillcolor="#161d28"];
  "turn-fl" [label="Front turn LEFT", fillcolor="#161d28"];
  "turn-fr" [label="Front turn RIGHT", fillcolor="#161d28"];
  "side-l" [label="Side marker/repeater LEFT", fillcolor="#161d28"];
  "side-r" [label="Side marker/repeater RIGHT", fillcolor="#161d28"];
  "horn-hi" [label="Horn", fillcolor="#161d28"];
  "horn-lo" [label="Horn", fillcolor="#161d28"];
  { rank=min; "bh4"; }
  { rank=max; "hl-L"; "hl-R"; "park-fl"; "park-fr"; "turn-fl"; "turn-fr"; "side-l"; "side-r"; "horn-hi"; "horn-lo"; }
  "battery" -> "pdm" [xlabel="PDM.+B", color="#9aa7b8", fontcolor="#9aa7b8"];
  "bh4" -> "pdm" [xlabel="HL.LO.TRG", color="#f5c451", fontcolor="#f5c451"];
  "bh4" -> "pdm" [xlabel="HL.HI.TRG", color="#f5c451", fontcolor="#f5c451"];
  "pdm" -> "hl-L" [xlabel="HL.LO.OUT.L", color="#f5c451", fontcolor="#f5c451"];
  "pdm" -> "hl-R" [xlabel="HL.LO.OUT.R", color="#f5c451", fontcolor="#f5c451"];
  "pdm" -> "hl-L" [xlabel="HL.HI.OUT.L", color="#f5c451", fontcolor="#f5c451"];
  "pdm" -> "hl-R" [xlabel="HL.HI.OUT.R", color="#f5c451", fontcolor="#f5c451"];
  "pdm" -> "bh4" [xlabel="HL.HI.TELL", color="#f5c451", fontcolor="#f5c451"];
  "bh4" -> "park-fl" [xlabel="POS.OUT.F", color="#8bd17c", fontcolor="#8bd17c"];
  "park-fl" -> "park-fr" [xlabel="POS.FRONT.JMP", color="#8bd17c", fontcolor="#8bd17c"];
  "bh4" -> "turn-fl" [xlabel="TURN.L.OUT.F", color="#56b4e9", fontcolor="#56b4e9"];
  "bh4" -> "turn-fr" [xlabel="TURN.R.OUT.F", color="#56b4e9", fontcolor="#56b4e9"];
  "turn-fl" -> "side-l" [xlabel="SIDE.L", color="#56b4e9", fontcolor="#56b4e9"];
  "turn-fr" -> "side-r" [xlabel="SIDE.R", color="#56b4e9", fontcolor="#56b4e9"];
  "bh4" -> "horn-hi" [xlabel="HORN.OUT", color="#9a9a9a", fontcolor="#9a9a9a"];
  "horn-hi" -> "horn-lo" [xlabel="HORN.OUT2", color="#9a9a9a", fontcolor="#9a9a9a"];
}
