digraph "switch-cluster" {
  rankdir=LR; bgcolor="transparent"; splines=ortho; forcelabels=true; nodesep=0.45; ranksep=1.1;
  node [shape=box, style="rounded,filled", color="#2a323f", fontcolor="#e7ecf3", fontsize=10, fontname="Helvetica"];
  edge [dir=none, fontsize=8, fontname="Helvetica", fontcolor="#cdd0c4"];
  "sw-instr" [label="Instrument-light switch", fillcolor="#161d28"];
  "sw3" [label="SW3", fillcolor="#1c2530", color="#5a6678", penwidth=2];
  "sw-wiper" [label="Wiper switch", fillcolor="#161d28"];
  "sw-heaterfan" [label="Heater-fan switch", fillcolor="#161d28"];
  { rank=min; "sw3"; }
  "sw-instr" -> "sw3" [xlabel="ILL.DIM", color="#b07cd1", fontcolor="#b07cd1"];
  "sw-instr" -> "sw3" [xlabel="ILL.BRT", color="#b07cd1", fontcolor="#b07cd1"];
  "sw3" -> "sw-wiper" [xlabel="SW3.+I", color="#b07cd1", fontcolor="#b07cd1"];
  "sw-wiper" -> "sw-instr" [xlabel="SW3.+I.J1", color="#b07cd1", fontcolor="#b07cd1"];
  "sw-instr" -> "sw-heaterfan" [xlabel="SW3.+I.J2", color="#b07cd1", fontcolor="#b07cd1"];
  "sw-wiper" -> "sw3" [xlabel="WIPE.LO.TRG", color="#4bc0c0", fontcolor="#4bc0c0"];
  "sw-wiper" -> "sw3" [xlabel="WIPE.HI.TRG", color="#4bc0c0", fontcolor="#4bc0c0"];
  "sw-heaterfan" -> "sw3" [xlabel="FAN.TRG", color="#7cd1c4", fontcolor="#7cd1c4"];
}
