digraph "dashboard" {
  rankdir=LR; bgcolor="transparent"; splines=ortho; forcelabels=true; nodesep=0.45; ranksep=1.1;
  node [shape=box, style="rounded,filled", color="#2a323f", fontcolor="#e7ecf3", fontsize=10, fontname="Helvetica"];
  edge [dir=none, fontsize=8, fontname="Helvetica", fontcolor="#cdd0c4"];
  "bh1" [label="BH1", fillcolor="#1c2530", color="#5a6678", penwidth=2];
  "wl-charge" [label="Warning", fillcolor="#161d28"];
  "ign-switch" [label="Ignition switch", fillcolor="#161d28"];
  "sw-headlight" [label="Headlight switch", fillcolor="#161d28"];
  "sw-dipflash" [label="Dip / flash", fillcolor="#161d28"];
  "bh2" [label="BH2", fillcolor="#1c2530", color="#5a6678", penwidth=2];
  "wl-main" [label="Tell-tale", fillcolor="#161d28"];
  "sw-turn" [label="Turn-signal switch", fillcolor="#161d28"];
  "wl-turn" [label="Tell-tale", fillcolor="#161d28"];
  "sw-hazard" [label="Hazard switch", fillcolor="#161d28"];
  "g-fuel" [label="Fuel gauge", fillcolor="#161d28"];
  "snd-fuel" [label="Fuel-tank sender", fillcolor="#161d28"];
  "g-temp" [label="Coolant-temp gauge", fillcolor="#161d28"];
  "g-oil" [label="Oil-pressure gauge", fillcolor="#161d28"];
  "wl-oil" [label="Warning", fillcolor="#161d28"];
  "g-tach" [label="Tachometer", fillcolor="#161d28"];
  "sw-washer" [label="Washer push button", fillcolor="#161d28"];
  "sw-horn" [label="Horn button", fillcolor="#161d28"];
  "int-light" [label="Interior / courtesy light", fillcolor="#161d28"];
  "sw-door-l" [label="Door switch LEFT", fillcolor="#161d28"];
  "sw-door-r" [label="Door switch RIGHT", fillcolor="#161d28"];
  "usb-charge" [label="USB-C charge port", fillcolor="#161d28"];
  "stereo" [label="Stereo", fillcolor="#161d28"];
  { rank=min; "bh1"; "bh2"; }
  { rank=max; "wl-charge"; "wl-main"; "wl-turn"; "g-fuel"; "snd-fuel"; "g-temp"; "g-oil"; "wl-oil"; "g-tach"; "int-light"; }
  "bh1" -> "wl-charge" [xlabel="CHG.L", color="#e8b04b", fontcolor="#e8b04b"];
  "ign-switch" -> "bh1" [xlabel="STRT.TRG", color="#c98a4b", fontcolor="#c98a4b"];
  "bh1" -> "ign-switch" [xlabel="IGN.30.+B", color="#e2554a", fontcolor="#e2554a"];
  "ign-switch" -> "bh1" [xlabel="IGN.MAIN.TRG", color="#e2554a", fontcolor="#e2554a"];
  "ign-switch" -> "sw-headlight" [xlabel="HL.EN.+I", color="#f5c451", fontcolor="#f5c451"];
  "sw-headlight" -> "sw-dipflash" [xlabel="HL.HEAD", color="#f5c451", fontcolor="#f5c451"];
  "ign-switch" -> "sw-dipflash" [xlabel="HL.FLASH.+I", color="#f5c451", fontcolor="#f5c451"];
  "sw-dipflash" -> "bh2" [xlabel="HL.LO.TRG", color="#f5c451", fontcolor="#f5c451"];
  "sw-dipflash" -> "bh2" [xlabel="HL.HI.TRG", color="#f5c451", fontcolor="#f5c451"];
  "bh2" -> "wl-main" [xlabel="HL.HI.TELL", color="#f5c451", fontcolor="#f5c451"];
  "bh1" -> "sw-turn" [xlabel="TURN.SW.+I", color="#56b4e9", fontcolor="#56b4e9"];
  "sw-turn" -> "bh2" [xlabel="TURN.L.TRG", color="#56b4e9", fontcolor="#56b4e9"];
  "sw-turn" -> "bh2" [xlabel="TURN.R.TRG", color="#56b4e9", fontcolor="#56b4e9"];
  "bh2" -> "wl-turn" [xlabel="TURN.TELL.L", color="#56b4e9", fontcolor="#56b4e9"];
  "bh2" -> "wl-turn" [xlabel="TURN.TELL.R", color="#56b4e9", fontcolor="#56b4e9"];
  "bh1" -> "sw-hazard" [xlabel="HAZ.+B", color="#56b4e9", fontcolor="#56b4e9"];
  "sw-hazard" -> "bh2" [xlabel="HAZ.L.TRG", color="#56b4e9", fontcolor="#56b4e9"];
  "sw-hazard" -> "bh2" [xlabel="HAZ.R.TRG", color="#56b4e9", fontcolor="#56b4e9"];
  "bh1" -> "g-fuel" [xlabel="GAUGE.+I", color="#b07cd1", fontcolor="#b07cd1"];
  "snd-fuel" -> "g-fuel" [xlabel="FUEL.SIG", color="#b07cd1", fontcolor="#b07cd1"];
  "bh1" -> "g-temp" [xlabel="TEMP.SIG", color="#b07cd1", fontcolor="#b07cd1"];
  "bh1" -> "g-oil" [xlabel="OILP.SIG", color="#b07cd1", fontcolor="#b07cd1"];
  "bh1" -> "wl-oil" [xlabel="OIL.WL", color="#b07cd1", fontcolor="#b07cd1"];
  "bh1" -> "g-tach" [xlabel="TACH.SIG", color="#b07cd1", fontcolor="#b07cd1"];
  "g-fuel" -> "wl-oil" [xlabel="WL.+I", color="#b07cd1", fontcolor="#b07cd1"];
  "bh1" -> "g-fuel" [xlabel="ILL.OUT", color="#b07cd1", fontcolor="#b07cd1"];
  "bh1" -> "sw-washer" [xlabel="WASH.+I", color="#4bc0c0", fontcolor="#4bc0c0"];
  "sw-washer" -> "bh1" [xlabel="WASH.TRG", color="#4bc0c0", fontcolor="#4bc0c0"];
  "bh2" -> "sw-horn" [xlabel="HORN.TRG", color="#9a9a9a", fontcolor="#9a9a9a"];
  "bh1" -> "int-light" [xlabel="INT.+B", color="#9a9a9a", fontcolor="#9a9a9a"];
  "int-light" -> "sw-door-l" [xlabel="INT.DOOR.L", color="#9a9a9a", fontcolor="#9a9a9a"];
  "int-light" -> "sw-door-r" [xlabel="INT.DOOR.R", color="#9a9a9a", fontcolor="#9a9a9a"];
  "bh1" -> "usb-charge" [xlabel="ACC.+I", color="#9a9a9a", fontcolor="#9a9a9a"];
  "usb-charge" -> "stereo" [xlabel="ACC.STEREO.JMP", color="#9a9a9a", fontcolor="#9a9a9a"];
}
